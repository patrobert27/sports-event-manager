# Configuración del Servidor
PORT=3001

# Base de Datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jornades_db
DB_USER=postgres
DB_PASSWORD=postgres

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Seguridad
JWT_SECRET=your-jwt-secret-key

# Configuració Email (SMTP Gmail)
MAIL_SMTP_SERVER=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SENDER_ADDR=your-email@example.com
MAIL_SENDER_PASSWORD=your-app-password
MAIL_SENDER_NAME=Jornades Esportives

# Contacto
CONTACT_ADDR=your-contact-email@example.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Habilitar Login de Desarrollo (true/false)
ENABLE_DEV_LOGIN=true
