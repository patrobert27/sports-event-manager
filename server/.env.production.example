# Configuración del Servidor
PORT=3000

# Base de Datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jornades_db
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Google OAuth 2.0 (Producción)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://your-domain.com/api/auth/google/callback

# Seguridad
JWT_SECRET=your-jwt-secret-key

# Configuració Email (SMTP Gmail)
MAIL_SMTP_SERVER=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SENDER_ADDR=your-email@example.com
MAIL_SENDER_PASSWORD=your-app-password
MAIL_SENDER_NAME=Jornades Esportives

# Contacto
CONTACT_ADDR=your-contact-email@example.com

# URLs
FRONTEND_URL=http://your-domain.com
ENABLE_DEV_LOGIN=false
